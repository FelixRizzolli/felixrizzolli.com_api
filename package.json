{
  "name": "api-felixrizzolli-com",
  "version": "1.0.0-beta.8",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --hostname \"${API_HOST}\" --port \"${API_PORT}\"",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" pnpm exec playwright test",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.79.1",
    "@payloadcms/next": "3.79.1",
    "@payloadcms/payload-cloud": "3.79.1",
    "@payloadcms/plugin-multi-tenant": "3.79.1",
    "@payloadcms/richtext-lexical": "3.79.1",
    "@payloadcms/translations": "3.79.1",
    "@payloadcms/ui": "3.79.1",
    "cross-env": "10.1.0",
    "dotenv": "17.3.1",
    "graphql": "16.13.2",
    "next": "16.2.0",
    "payload": "3.79.1",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "jsdom": "29.0.1",
    "oxfmt": "0.41.0",
    "oxlint": "1.57.0",
    "playwright": "1.58.2",
    "playwright-core": "1.58.2",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.0"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "dompurify@<3.2.4": ">=3.2.4",
      "fast-xml-parser@>=5.0.9 <=5.3.3": ">=5.3.4",
      "fast-xml-parser@>=5.0.0 <5.3.5": ">=5.3.5",
      "fast-xml-parser@>=5.0.0 <5.3.6": ">=5.3.6",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "dompurify@>=3.1.3 <3.2.7": ">=3.2.7",
      "dompurify@>=3.1.3 <=3.3.1": ">=3.3.2",
      "fast-xml-parser@>=5.0.0 <5.3.8": ">=5.3.8",
      "file-type@>=13.0.0 <21.3.1": ">=21.3.1",
      "undici@>=7.0.0 <7.24.0": ">=7.24.0",
      "undici@>=7.17.0 <7.24.0": ">=7.24.0",
      "fast-xml-parser@>=4.0.0-beta.3 <=5.5.5": ">=5.5.6"
    }
  }
}
